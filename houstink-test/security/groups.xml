<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_sale_custom" model="ir.module.category">
            <field name="name">Ventas Personalizado</field>
        </record>

        <record id="group_sale_order_viewer" model="res.groups">
            <field name="name">Group A: Lector de Cotizaciones</field>
            <field name="category_id" ref="module_category_sale_custom" />
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
        </record>

        <record id="group_sale_order_manager" model="res.groups">
            <field name="name">Group B: Confirmador de Pedidos</field>
            <field name="category_id" ref="module_category_sale_custom" />
            <field name="implied_ids" eval="[(4, ref('group_sale_order_viewer'))]" />
        </record>
    </data>
</odoo>