<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_saleorder_document_custom" inherit_id="sale.report_saleorder_document">

            <xpath expr="//t[@t-set='address']" position="replace">
                <t t-set="address">
                </t>
            </xpath>

            <xpath expr="//t[@t-set='information_block']" position="replace">
                <t t-set="information_block">
                </t>
            </xpath>

            <xpath expr="//t[@t-set='layout_document_title']" position="replace">
                <t t-set="layout_document_title">
                    <div style="color: #002366; font-weight: bold;">
                        <span t-if="is_proforma">Pro-Forma Invoice # </span>
                        <span t-elif="doc.state in ['draft','sent']">Cotización # </span>
                        <span t-else="">Order # </span>
                        <span t-field="doc.name">SO0000</span>
                    </div>
                </t>
            </xpath>

            <xpath expr="//t[@t-set='layout_document_title']" position="after">
                <div
                    style="color: #002366; font-weight: bold; font-size: 1.2em; margin-bottom: 10px;">
                    Propuesta Comercial Personalizada
                </div>
            </xpath>

            <xpath expr="//div[@id='informations']/div[last()]" position="replace">
                <div class="col" name="informations_customer">
                    <strong>Cliente:</strong>
                    <div t-field="doc.partner_id.name"
                        style="text-transform: uppercase; color: #E67E22; font-size: 1.4em; font-weight: bold;" />
                </div>
            </xpath>

            <xpath expr="//div[@id='total']" position="before">
                <div class="mt-3 mb-3"
                    style="border-left: 4px solid #002366; padding-left: 15px; background-color: #f8f9fa; padding-top: 5px; padding-bottom: 5px;">
                    <strong style="color: #002366;">Condiciones Especiales:</strong>
                    <ul style="margin-bottom: 0;">
                        <li>Entrega sujeta a disponibilidad.</li>
                        <li>Precios válidos por 15 días.</li>
                    </ul>
                </div>
            </xpath>

            <xpath expr="//div[@id='total']//table" position="attributes">
                <attribute name="style">background-color: #F2F2F2 !important; border: 1px solid
                    #ddd; font-weight: bold; font-size: 1.2em;</attribute>
            </xpath>

        </template>
    </data>
</odoo>