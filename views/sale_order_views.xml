<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_order_form_inherit_total_lines" model="ir.ui.view">
            <field name="name">sale.order.form.inherit.total.lines</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form" />
            <field name="arch" type="xml">

                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="x_total_lines" readonly="1" />
                </xpath>

                <xpath expr="//button[@name='action_confirm']" position="attributes">
                    <attribute name="groups">houstink-test.group_sale_order_manager</attribute>
                </xpath>

            </field>
        </record>

        <record id="sale.action_quotations_with_onboarding" model="ir.actions.act_window">
            <field name="name">Quotations</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">sale.order</field>
            <field name="context">{'search_default_my_quotation': 0}</field>
        </record>
    </data>
</odoo>